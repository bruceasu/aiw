{
  // Output binary name prefix.
  "projectName": "aiw",

  // Go build entry package/file. If empty: main.go (if exists) else "."
  "entry": ".",

  // Build artifact directory.
  "outputDir": "bin",

  // Default install target directory for "install".
  "installDir": "c:\\green",

  // Used by "build all". Non-available platforms in current toolchain are skipped.
  "allPlatforms": [
    "windows/386",
    "windows/amd64",
    "windows/arm64",
    "linux/386",
    "linux/amd64",
    "linux/arm64",
    "darwin/386",
    "darwin/amd64",
    "darwin/arm64"
  ]
}
